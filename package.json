{
	"name": "media-service",
	"version": "1.0.0",
	"description": "Service de gestion des médias pour l'application Whispr",
	"author": "Whispr Team",
	"private": true,
	"license": "UNLICENSED",
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=10.0.0"
	},
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"lint-staged": "npx lint-staged",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"test:e2e:docker": "ts-node test/docker/docker-e2e-runner.ts",
		"test:e2e:docker:run": "jest --config ./test/docker/jest-docker-e2e.json",
		"test:e2e:docker:cleanup": "ts-node test/docker/docker-e2e-runner.ts --cleanup",
		"typeorm": "typeorm-ts-node-commonjs",
		"migration:generate": "npm run typeorm -- migration:generate -d src/config/typeorm.config.ts",
		"migration:run": "npm run typeorm -- migration:run -d src/config/typeorm.config.ts",
		"migration:revert": "npm run typeorm -- migration:revert -d src/config/typeorm.config.ts",
		"docker:build": "docker build -t media-service .",
		"docker:run": "docker run -p 3000:3000 media-service",
		"prepare": "husky"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1033.0",
		"@aws-sdk/s3-request-presigner": "^3.1033.0",
		"@google-cloud/secret-manager": "^6.1.1",
		"@google-cloud/storage": "^6.12.0",
		"@grpc/grpc-js": "^1.14.3",
		"@grpc/proto-loader": "^0.8.0",
		"@keyv/redis": "^5.1.5",
		"@nest-lab/throttler-storage-redis": "^1.2.0",
		"@nestjs/cache-manager": "^3.1.0",
		"@nestjs/common": "^11.1.18",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.18",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/mapped-types": "^2.1.0",
		"@nestjs/microservices": "^11.1.19",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.1.12",
		"@nestjs/platform-fastify": "^11.1.18",
		"@nestjs/schedule": "^6.1.1",
		"@nestjs/swagger": "^11.2.7",
		"@nestjs/terminus": "^11.0.0",
		"@nestjs/throttler": "^6.5.0",
		"@nestjs/typeorm": "^11.0.0",
		"@nestjs/websockets": "^11.1.12",
		"bcrypt": "^6.0.0",
		"cache-manager": "^7.2.8",
		"cache-manager-redis-store": "^3.0.1",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.3",
		"compression": "^1.8.1",
		"crypto": "^1.0.1",
		"express-rate-limit": "^6.8.1",
		"fluent-ffmpeg": "^2.1.2",
		"helmet": "^8.1.0",
		"ioredis": "^5.9.2",
		"joi": "^17.9.2",
		"multer": "^1.4.5-lts.1",
		"nest-winston": "^1.9.4",
		"nestjs-s3": "^3.0.1",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"passport-local": "^1.0.0",
		"pg": "^8.17.1",
		"prom-client": "^14.2.0",
		"prometheus-api-metrics": "^3.2.2",
		"redis": "^5.10.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"sharp": "^0.32.1",
		"swagger-ui-express": "^5.0.1",
		"typeorm": "^0.3.28",
		"uuid": "^13.0.0",
		"winston": "^3.10.0"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.16",
		"@nestjs/schematics": "^11.0.9",
		"@nestjs/testing": "^11.1.12",
		"@swc/cli": "^0.7.10",
		"@swc/core": "^1.15.8",
		"@types/bcrypt": "^6.0.0",
		"@types/compression": "^1.8.1",
		"@types/express": "^5.0.6",
		"@types/fluent-ffmpeg": "^2.1.21",
		"@types/jest": "^30.0.0",
		"@types/multer": "^1.4.7",
		"@types/node": "^25.0.9",
		"@types/passport-jwt": "^4.0.1",
		"@types/passport-local": "^1.0.35",
		"@types/supertest": "^2.0.12",
		"@types/uuid": "^9.0.2",
		"@typescript-eslint/eslint-plugin": "^8.47.0",
		"@typescript-eslint/parser": "^8.47.0",
		"eslint": "^8.42.0",
		"eslint-config-prettier": "^8.8.0",
		"eslint-plugin-jest": "^29.12.1",
		"eslint-plugin-prettier": "^5.0.0",
		"husky": "^9.1.7",
		"jest": "^29.5.0",
		"lint-staged": "^15.5.2",
		"prettier": "^3.8.1",
		"source-map-support": "^0.5.21",
		"supertest": "^6.3.4",
		"ts-jest": "^29.1.0",
		"ts-loader": "^9.4.3",
		"ts-node": "^10.9.1",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.1.3"
	},
	"prettier": {
		"trailingComma": "es5",
		"useTabs": true,
		"tabWidth": 4,
		"semi": true,
		"singleQuote": true,
		"printWidth": 110
	},
	"lint-staged": {
		"{src,test}/**/*.{js,ts,tsx,jsx}": [
			"eslint --fix",
			"prettier --write"
		]
	}
}
